{
  "name": "phibo",
  "displayName": "Phibo",
  "version": "0.0.40",
  "description": "Minimal Plasmo browser extension with a popup and dashboard page.",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
